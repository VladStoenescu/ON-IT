# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# All runtime data files — never commit user data to the repository.
# On first boot the server creates these files automatically in DATA_DIR.
# For DigitalOcean App Platform set DATA_DIR=/data (persistent volume, see .do/app.yaml).
# For PM2 / bare-metal deployments set DATA_DIR=/opt/on-it-data (outside the git repo).
data/*.json
# Temp files created by the atomic-write helper (writeJson); normally transient
# but can be left behind after a crash.
data/*.tmp

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# PM2
.pm2/
